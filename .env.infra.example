# Example .env.infra — Infrastructure config
# Copy to ~/.autodeploy/.env.infra and fill in your values

# ─── Dokploy ───────────────────────────────────────────
# Your Dokploy dashboard URL
DOKPLOY_URL="https://projects.yourdomain.com"

# API key from: Dokploy > Settings > Profile > API/CLI Section
DOKPLOY_API_KEY="your-dokploy-api-key"

# ─── Supabase (self-hosted) ────────────────────────────
# Studio dashboard URL
SUPABASE_URL="https://supabase.yourdomain.com"

# Kong API gateway URL (where REST/Auth/Storage APIs live)
SUPABASE_API_URL="https://supabase-api.yourdomain.com"

# Anon key from: Supabase Studio > Settings > API
SUPABASE_ANON_KEY="eyJ..."

# Service role key from: Supabase Studio > Settings > API
SUPABASE_SERVICE_KEY="eyJ..."

# ─── Domain ────────────────────────────────────────────
# Your root domain — apps will be deployed as <name>.<suffix>
DOMAIN_SUFFIX="yourdomain.com"

# ─── Cloudflare Tunnel ─────────────────────────────────
# CNAME target for your tunnel
# Get from: Cloudflare > Zero Trust > Networks > Tunnels > your tunnel
CF_TUNNEL_CNAME="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.cfargotunnel.com"

# Tunnel UUID (the part before .cfargotunnel.com)
CF_TUNNEL_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Cloudflare Account ID
# Get from: Cloudflare dashboard > any domain > Overview > right sidebar
CF_ACCOUNT_ID="your-account-id"

# ─── Dokploy Internal Routing ──────────────────────────
# Internal IP:port where Dokploy's Traefik reverse proxy listens
# This is the target for Cloudflare Tunnel ingress rules
# Usually http://<your-server-internal-ip>:80
DOKPLOY_TRAEFIK_TARGET="http://172.16.0.1:80"
