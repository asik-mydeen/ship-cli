  # Nixpacks needs a Procfile for Python
  cat > Procfile << EOF
web: uvicorn main:app --host 0.0.0.0 --port \${PORT:-$APP_PORT}
EOF

  cat > .env.example << EOF
PORT=$APP_PORT
$(echo "$SUPA_ENV" | sed 's/NEXT_PUBLIC_//g')
EOF

  ok "FastAPI scaffold ready"
}

