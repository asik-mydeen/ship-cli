#!/usr/bin/env bash
set -euo pipefail

# ═══════════════════════════════════════════════════════════════════
#  ship — Zero-fuss project scaffold → GitHub → Dokploy → Supabase
#  Usage: ship [new|deploy|status|destroy]
# ═══════════════════════════════════════════════════════════════════

SCRIPT_DIR="$HOME/.autodeploy"
ENV_FILE="$SCRIPT_DIR/.env"
INFRA_FILE="$SCRIPT_DIR/.env.infra"
TEMPLATES_DIR="$SCRIPT_DIR/templates"

# ── Colors ──
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'
DIM='\033[2m'; NC='\033[0m'

# ── Helpers ──
info()  { echo -e "${BLUE}▸${NC} $*"; }
ok()    { echo -e "${GREEN}✔${NC} $*"; }
warn()  { echo -e "${YELLOW}⚠${NC} $*"; }
fail()  { echo -e "${RED}✘${NC} $*"; exit 1; }
header(){ echo -e "\n${BOLD}${CYAN}═══ $* ═══${NC}\n"; }

api_dokploy() {
  local endpoint="$1"; shift
  curl -sf -X POST "$DOKPLOY_URL/api/$endpoint" \
    -H "x-api-key: $DOKPLOY_API_KEY" \
    -H "Content-Type: application/json" \
    "$@"
}

api_github() {
  local method="$1" endpoint="$2"; shift 2
  curl -sf -X "$method" "https://api.github.com$endpoint" \
    -H "Authorization: token $GITHUB_PAT" \
    -H "Accept: application/vnd.github.v3+json" \
    "$@"
}

# ── Load config ──
load_config() {
  [[ -f "$ENV_FILE" ]] || fail "Missing $ENV_FILE — run setup first"
  [[ -f "$INFRA_FILE" ]] || fail "Missing $INFRA_FILE"
  set -a
  source "$ENV_FILE"
  source "$INFRA_FILE"
  set +a
  [[ -n "${GITHUB_PAT:-}" ]] || fail "GITHUB_PAT not set in $ENV_FILE"
  [[ -n "${GITHUB_USERNAME:-}" ]] || fail "GITHUB_USERNAME not set in $ENV_FILE"
}

# ═══════════════════════════════════════════════════════════════════
#  COMMAND: new — Interactive project creation
# ═══════════════════════════════════════════════════════════════════
cmd_new() {
  load_config
  header "Create New Project"

  # ── Gather info ──
  echo -e "${BOLD}Project name${NC} ${DIM}(lowercase, hyphens ok)${NC}"
  read -rp "→ " PROJECT_NAME
  PROJECT_NAME=$(echo "$PROJECT_NAME" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-')
  [[ -n "$PROJECT_NAME" ]] || fail "Project name required"

  echo ""
  echo -e "${BOLD}Description${NC} ${DIM}(one line)${NC}"
  read -rp "→ " PROJECT_DESC
  PROJECT_DESC="${PROJECT_DESC:-$PROJECT_NAME}"

  echo ""
  echo -e "${BOLD}Project type${NC}"
  echo "  1) node     — Next.js / Express / Fastify"
  echo "  2) python   — FastAPI / Flask"
  echo "  3) rust     — Actix / Axum"
  read -rp "→ [1/2/3] " TYPE_CHOICE
  case "${TYPE_CHOICE:-1}" in
    1|node)   PROJECT_TYPE="node" ;;
    2|python) PROJECT_TYPE="python" ;;
    3|rust)   PROJECT_TYPE="rust" ;;
    *)        PROJECT_TYPE="node" ;;
  esac

  echo ""
  echo -e "${BOLD}Framework${NC}"
  case "$PROJECT_TYPE" in
    node)
      echo "  1) nextjs   — Full-stack React (default)"
      echo "  2) express  — REST API"
      echo "  3) fastify  — High-perf API"
      read -rp "→ [1/2/3] " FW_CHOICE
      case "${FW_CHOICE:-1}" in
        2|express) FRAMEWORK="express" ;;
        3|fastify) FRAMEWORK="fastify" ;;
        *)         FRAMEWORK="nextjs" ;;
      esac
      ;;
    python)
      echo "  1) fastapi  — Async API (default)"
      echo "  2) flask    — Classic web"
      read -rp "→ [1/2] " FW_CHOICE
      case "${FW_CHOICE:-1}" in
        2|flask) FRAMEWORK="flask" ;;
        *)       FRAMEWORK="fastapi" ;;
      esac
      ;;
    rust)
      echo "  1) axum     — Tokio-based (default)"
      echo "  2) actix    — Actor-based"
      read -rp "→ [1/2] " FW_CHOICE
      case "${FW_CHOICE:-1}" in
        2|actix) FRAMEWORK="actix" ;;
        *)       FRAMEWORK="axum" ;;
      esac
      ;;
  esac

  echo ""
  echo -e "${BOLD}Port${NC} ${DIM}(internal app port, default: 3000)${NC}"
  read -rp "→ " APP_PORT
  APP_PORT="${APP_PORT:-3000}"

  echo ""
  echo -e "${BOLD}Subdomain${NC} ${DIM}(will be <name>.$DOMAIN_SUFFIX, default: $PROJECT_NAME)${NC}"
  read -rp "→ " SUBDOMAIN
  SUBDOMAIN="${SUBDOMAIN:-$PROJECT_NAME}"
  FULL_DOMAIN="${SUBDOMAIN}.${DOMAIN_SUFFIX}"

  echo ""
  echo -e "${BOLD}Include Supabase?${NC} ${DIM}(auth, database, storage — default: yes)${NC}"
  read -rp "→ [Y/n] " USE_SUPABASE
  USE_SUPABASE="${USE_SUPABASE:-y}"

  # ── Summary ──
  header "Summary"
  echo -e "  Name:       ${BOLD}$PROJECT_NAME${NC}"
  echo -e "  Type:       ${BOLD}$PROJECT_TYPE / $FRAMEWORK${NC}"
  echo -e "  Domain:     ${BOLD}https://$FULL_DOMAIN${NC}"
  echo -e "  Port:       ${BOLD}$APP_PORT${NC}"
  echo -e "  Supabase:   ${BOLD}$(echo "$USE_SUPABASE" | grep -qi 'n' && echo 'No' || echo 'Yes')${NC}"
  echo -e "  GitHub:     ${BOLD}$GITHUB_USERNAME/$PROJECT_NAME${NC}"
  echo ""
  read -rp "Proceed? [Y/n] " CONFIRM
  echo "$CONFIRM" | grep -qi 'n' && { echo "Aborted."; exit 0; }

  # ═══ Step 1: Scaffold project ═══
  header "1/6  Scaffolding $PROJECT_TYPE/$FRAMEWORK project"
  scaffold_project

  # ═══ Step 2: Create GitHub repo ═══
  header "2/6  Creating GitHub repository"
  create_github_repo

  # ═══ Step 3: Push code ═══
  header "3/6  Pushing to GitHub"
  push_to_github

  # ═══ Step 4: Create Dokploy project + app ═══
  header "4/8  Setting up Dokploy"
  setup_dokploy

  # ═══ Step 5: Create Cloudflare DNS record ═══
  header "5/8  Creating DNS record"
  setup_dns

  # ═══ Step 6: Configure GitHub Actions for auto-deploy ═══
  header "6/8  Setting up GitHub Actions auto-deploy"
  setup_github_actions

  # ═══ Step 7: Push workflow to GitHub ═══
  header "7/8  Pushing deploy workflow"
  push_workflow

  # ═══ Step 8: Trigger first deploy ═══
  header "8/8  Triggering first deployment"
  trigger_deploy

  # ═══ Done ═══
  header "🚀 $PROJECT_NAME is LIVE"
  echo -e "  ${BOLD}App:${NC}        https://$FULL_DOMAIN"
  echo -e "  ${BOLD}GitHub:${NC}     https://github.com/$GITHUB_USERNAME/$PROJECT_NAME"
  echo -e "  ${BOLD}Dokploy:${NC}    $DOKPLOY_URL"
  echo -e "  ${BOLD}Supabase:${NC}   $SUPABASE_URL"
  echo ""
  echo -e "  ${DIM}Every push to main auto-deploys. Just code and push.${NC}"
  echo ""

  # Save project metadata locally
  echo "{
  \"name\": \"$PROJECT_NAME\",
  \"type\": \"$PROJECT_TYPE\",
  \"framework\": \"$FRAMEWORK\",
  \"domain\": \"$FULL_DOMAIN\",
  \"port\": $APP_PORT,
  \"dokploy_project_id\": \"$DOKPLOY_PROJECT_ID\",
  \"dokploy_app_id\": \"$DOKPLOY_APP_ID\",
  \"dokploy_env_id\": \"$DOKPLOY_ENV_ID\",
  \"github_repo\": \"$GITHUB_USERNAME/$PROJECT_NAME\",
  \"supabase\": $(echo "$USE_SUPABASE" | grep -qi 'n' && echo 'false' || echo 'true'),
  \"created\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"
}" > "$PROJECT_DIR/.ship.json"
  ok "Saved project config to .ship.json"
}

# ═══════════════════════════════════════════════════════════════════
#  Scaffold project files
# ═══════════════════════════════════════════════════════════════════
scaffold_project() {
  PROJECT_DIR="$(pwd)/$PROJECT_NAME"
  [[ -d "$PROJECT_DIR" ]] && fail "Directory $PROJECT_NAME already exists"
  mkdir -p "$PROJECT_DIR"
  cd "$PROJECT_DIR"

  # Supabase env lines
  local SUPA_ENV=""
  if ! echo "$USE_SUPABASE" | grep -qi 'n'; then
    SUPA_ENV="NEXT_PUBLIC_SUPABASE_URL=$SUPABASE_API_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=$SUPABASE_SERVICE_KEY"
  fi

  case "$FRAMEWORK" in
    nextjs)   scaffold_nextjs "$SUPA_ENV" ;;
    express)  scaffold_express "$SUPA_ENV" ;;
    fastify)  scaffold_fastify "$SUPA_ENV" ;;
    fastapi)  scaffold_fastapi "$SUPA_ENV" ;;
    flask)    scaffold_flask "$SUPA_ENV" ;;
    axum)     scaffold_axum "$SUPA_ENV" ;;
    actix)    scaffold_actix "$SUPA_ENV" ;;
  esac

  # Common files
  cat > .gitignore << 'GITIGNORE'
node_modules/
.env
.env.local
.env.*.local
__pycache__/
*.pyc
target/
dist/
.next/
.ship.json
GITIGNORE

  local DEV_CMD
  case "$PROJECT_TYPE" in
    node)   DEV_CMD="npm install && npm run dev" ;;
    python) DEV_CMD="pip install -r requirements.txt && uvicorn main:app --reload" ;;
    rust)   DEV_CMD="cargo run" ;;
  esac

  cat > README.md << EOF
# $PROJECT_NAME

$PROJECT_DESC

## Development

\`\`\`bash
$DEV_CMD
\`\`\`

## Deployment

Every push to \`main\` auto-deploys to **https://$FULL_DOMAIN** via Dokploy.

## Infrastructure

- **Hosting:** Dokploy on TrueNAS → $DOKPLOY_URL
- **Database:** Supabase → $SUPABASE_URL
- **Domain:** https://$FULL_DOMAIN
EOF

  ok "Project scaffolded at $PROJECT_DIR"
}

