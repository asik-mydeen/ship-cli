# ── Rust: Axum ──
scaffold_axum() {
  local SUPA_ENV="$1"

  cat > Cargo.toml << EOF
[package]
name = "$PROJECT_NAME"
version = "0.1.0"
edition = "2021"

[dependencies]
axum = "0.8"
tokio = { version = "1", features = ["full"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
tower-http = { version = "0.6", features = ["cors"] }
EOF

  mkdir -p src
  cat > src/main.rs << EOF
use axum::{routing::get, Json, Router};
use serde_json::{json, Value};
use std::env;

async fn root() -> Json<Value> {
    Json(json!({"status": "ok", "name": "$PROJECT_NAME"}))
}

async fn health() -> Json<Value> {
    Json(json!({"status": "ok"}))
}

#[tokio::main]
async fn main() {
    let port = env::var("PORT").unwrap_or_else(|_| "$APP_PORT".into());
    let addr = format!("0.0.0.0:{port}");
    let app = Router::new()
        .route("/", get(root))
        .route("/health", get(health));
    println!("🚀 $PROJECT_NAME on {addr}");
    let listener = tokio::net::TcpListener::bind(&addr).await.unwrap();
    axum::serve(listener, app).await.unwrap();
}
EOF

  cat > .env.example << EOF
PORT=$APP_PORT
$(echo "$SUPA_ENV" | sed 's/NEXT_PUBLIC_//g')
EOF

  ok "Axum scaffold ready"
}

# ── Rust: Actix ──
scaffold_actix() {
  local SUPA_ENV="$1"
  scaffold_axum "$SUPA_ENV"  # Same structure, swap deps
  sed -i '' 's/axum = "[^"]*"/actix-web = "4"/' Cargo.toml 2>/dev/null || true
  sed -i '' '/tower-http/d' Cargo.toml 2>/dev/null || true

  cat > src/main.rs << EOF
use actix_web::{web, App, HttpServer, HttpResponse};
use serde_json::json;
use std::env;

async fn root() -> HttpResponse {
    HttpResponse::Ok().json(json!({"status": "ok", "name": "$PROJECT_NAME"}))
}

async fn health() -> HttpResponse {
    HttpResponse::Ok().json(json!({"status": "ok"}))
}

#[actix_web::main]
async fn main() -> std::io::Result<()> {
    let port: u16 = env::var("PORT").unwrap_or_else(|_| "$APP_PORT".into()).parse().unwrap();
    println!("🚀 $PROJECT_NAME on 0.0.0.0:{port}");
    HttpServer::new(|| App::new().route("/", web::get().to(root)).route("/health", web::get().to(health)))
        .bind(("0.0.0.0", port))?.run().await
}
EOF

  ok "Actix scaffold ready"
}

# ═══════════════════════════════════════════════════════════════════
#  GitHub: Create repo
# ═══════════════════════════════════════════════════════════════════
create_github_repo() {
  info "Creating repo $GITHUB_USERNAME/$PROJECT_NAME..."

  local RESPONSE
  RESPONSE=$(api_github POST "/user/repos" \
    -d "{\"name\":\"$PROJECT_NAME\",\"description\":\"$PROJECT_DESC\",\"private\":false,\"auto_init\":false}" 2>&1) || {
    if echo "$RESPONSE" | grep -q "name already exists"; then
      warn "Repo already exists, using it"
      return 0
    fi
    fail "GitHub repo creation failed: $RESPONSE"
  }
  ok "Created https://github.com/$GITHUB_USERNAME/$PROJECT_NAME"
}

# ═══════════════════════════════════════════════════════════════════
#  Git: Initialize and push
# ═══════════════════════════════════════════════════════════════════
push_to_github() {
  cd "$PROJECT_DIR"
  git init -q
  git checkout -b main 2>/dev/null || true
  git add -A
  git commit -q -m "🚀 Initial scaffold via ship CLI

Type: $PROJECT_TYPE/$FRAMEWORK
Domain: https://$FULL_DOMAIN
Supabase: $(echo "$USE_SUPABASE" | grep -qi 'n' && echo 'no' || echo 'yes')"

  git remote add origin "https://x-access-token:${GITHUB_PAT}@github.com/${GITHUB_USERNAME}/${PROJECT_NAME}.git" 2>/dev/null || \
    git remote set-url origin "https://x-access-token:${GITHUB_PAT}@github.com/${GITHUB_USERNAME}/${PROJECT_NAME}.git"

  # GitHub needs a moment after repo creation before it accepts pushes
  local retries=0
  while ! git push -u origin main -q 2>/dev/null; do
    retries=$((retries + 1))
    if [[ $retries -ge 5 ]]; then
      fail "Could not push to GitHub after $retries attempts"
    fi
    warn "Push failed, retrying in 3s... ($retries/5)"
    sleep 3
  done
  ok "Code pushed to GitHub"
}

# ═══════════════════════════════════════════════════════════════════
#  Dokploy: Create project + application + domain + env
# ═══════════════════════════════════════════════════════════════════
setup_dokploy() {
  # 1. Create project
  info "Creating Dokploy project..."
  local PROJECT_RESULT
  PROJECT_RESULT=$(api_dokploy "project.create" \
    -d "{\"name\":\"$PROJECT_NAME\",\"description\":\"$PROJECT_DESC\"}")

  DOKPLOY_PROJECT_ID=$(echo "$PROJECT_RESULT" | python3 -c "import json,sys;print(json.load(sys.stdin)['project']['projectId'])")
  DOKPLOY_ENV_ID=$(echo "$PROJECT_RESULT" | python3 -c "import json,sys;print(json.load(sys.stdin)['environment']['environmentId'])")
  ok "Project created: $DOKPLOY_PROJECT_ID"

  # 2. Create application
  info "Creating application..."
  local APP_RESULT
  APP_RESULT=$(api_dokploy "application.create" \
    -d "{\"name\":\"$PROJECT_NAME\",\"environmentId\":\"$DOKPLOY_ENV_ID\"}")

  DOKPLOY_APP_ID=$(echo "$APP_RESULT" | python3 -c "import json,sys;print(json.load(sys.stdin)['applicationId'])")
  DOKPLOY_REFRESH_TOKEN=$(echo "$APP_RESULT" | python3 -c "import json,sys;print(json.load(sys.stdin)['refreshToken'])")
  ok "Application created: $DOKPLOY_APP_ID"

  # 3. Configure git source
  info "Configuring git source..."
  api_dokploy "application.update" \
    -d "{
      \"applicationId\":\"$DOKPLOY_APP_ID\",
      \"sourceType\":\"git\",
      \"customGitUrl\":\"https://github.com/$GITHUB_USERNAME/$PROJECT_NAME.git\",
      \"customGitBranch\":\"main\",
      \"customGitBuildPath\":\"/\",
      \"autoDeploy\":true
    }" > /dev/null
  ok "Git source configured"

  # 4. Set build type
  info "Setting build type (nixpacks)..."
  local BUILD_TYPE="nixpacks"
  api_dokploy "application.saveBuildType" \
    -d "{
      \"applicationId\":\"$DOKPLOY_APP_ID\",
      \"buildType\":\"$BUILD_TYPE\",
      \"dockerfile\":\"Dockerfile\",
      \"dockerContextPath\":null,
      \"dockerBuildStage\":null,
      \"herokuVersion\":\"24\",
      \"railpackVersion\":\"0.15.4\",
      \"publishDirectory\":null
    }" > /dev/null
  ok "Build type: $BUILD_TYPE"

  # 5. Set environment variables
  info "Setting environment variables..."
  local ENV_VARS="PORT=$APP_PORT
NODE_ENV=production"

  if ! echo "$USE_SUPABASE" | grep -qi 'n'; then
    case "$PROJECT_TYPE" in
      node)
        if [[ "$FRAMEWORK" == "nextjs" ]]; then
          ENV_VARS="$ENV_VARS
NEXT_PUBLIC_SUPABASE_URL=$SUPABASE_API_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=$SUPABASE_SERVICE_KEY"
        else
          ENV_VARS="$ENV_VARS
SUPABASE_URL=$SUPABASE_API_URL
SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=$SUPABASE_SERVICE_KEY"
        fi
        ;;
      python|rust)
        ENV_VARS="$ENV_VARS
SUPABASE_URL=$SUPABASE_API_URL
SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=$SUPABASE_SERVICE_KEY"
        ;;
    esac
  fi

  api_dokploy "application.saveEnvironment" \
    -d "{
      \"applicationId\":\"$DOKPLOY_APP_ID\",
      \"env\":$(echo "$ENV_VARS" | python3 -c "import json,sys;print(json.dumps(sys.stdin.read()))"),
      \"buildArgs\":\"\",
      \"buildSecrets\":\"\",
      \"createEnvFile\":true
    }" > /dev/null
  ok "Environment variables set"

  # 6. Add domain
  info "Adding domain $FULL_DOMAIN..."
  api_dokploy "domain.create" \
    -d "{
      \"applicationId\":\"$DOKPLOY_APP_ID\",
      \"host\":\"$FULL_DOMAIN\",
      \"https\":false,
      \"port\":$APP_PORT,
      \"path\":\"/\",
      \"certificateType\":\"none\"
    }" > /dev/null
  ok "Domain configured: https://$FULL_DOMAIN (TLS via Cloudflare)"
}

# ═══════════════════════════════════════════════════════════════════
#  Cloudflare: Create DNS record pointing to tunnel
# ═══════════════════════════════════════════════════════════════════
setup_dns() {
  if [[ -z "${CLOUDFLARE_API_TOKEN:-}" ]] || [[ -z "${CLOUDFLARE_ZONE_ID:-}" ]]; then
    warn "Cloudflare API not configured — add DNS record manually:"
    echo "  CNAME  $SUBDOMAIN → $CF_TUNNEL_CNAME  (proxied)"
    return 0
  fi

  # 1. Create CNAME record
  info "Creating DNS CNAME: $FULL_DOMAIN → Cloudflare Tunnel..."
  curl -sf -X POST "https://api.cloudflare.com/client/v4/zones/$CLOUDFLARE_ZONE_ID/dns_records" \
    -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN" \
    -H "Content-Type: application/json" \
    -d "{
      \"type\": \"CNAME\",
      \"name\": \"$SUBDOMAIN\",
      \"content\": \"$CF_TUNNEL_CNAME\",
      \"proxied\": true,
      \"ttl\": 1
    }" > /dev/null 2>&1 && ok "DNS CNAME created" || warn "DNS record may already exist"

  # 2. Add Cloudflare Tunnel ingress rule
  if [[ -n "${CF_TUNNEL_ID:-}" ]] && [[ -n "${CF_ACCOUNT_ID:-}" ]]; then
    info "Adding Cloudflare Tunnel ingress: $FULL_DOMAIN → $DOKPLOY_TRAEFIK_TARGET..."
    local CURRENT_CONFIG
    CURRENT_CONFIG=$(curl -sf "https://api.cloudflare.com/client/v4/accounts/$CF_ACCOUNT_ID/cfd_tunnel/$CF_TUNNEL_ID/configurations" \
      -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN")

    local NEW_CONFIG
    NEW_CONFIG=$(echo "$CURRENT_CONFIG" | python3 -c "
import json,sys
d = json.load(sys.stdin)
config = d['result']['config']
ingress = config['ingress']
hostname = '$FULL_DOMAIN'
target = '$DOKPLOY_TRAEFIK_TARGET'
if not any(r.get('hostname') == hostname for r in ingress):
    ingress.insert(-1, {'hostname': hostname, 'service': target})
print(json.dumps({'config': config}))
")

    curl -sf -X PUT "https://api.cloudflare.com/client/v4/accounts/$CF_ACCOUNT_ID/cfd_tunnel/$CF_TUNNEL_ID/configurations" \
      -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN" \
      -H "Content-Type: application/json" \
      -d "$NEW_CONFIG" > /dev/null 2>&1 && ok "Tunnel ingress rule added" || warn "Could not add tunnel rule"
  fi
}

# ═══════════════════════════════════════════════════════════════════
#  GitHub Actions: Auto-deploy workflow + repo secrets
# ═══════════════════════════════════════════════════════════════════
setup_github_actions() {
  # 1. Create the workflow file
  info "Creating deploy workflow..."
  mkdir -p "$PROJECT_DIR/.github/workflows"
  cat > "$PROJECT_DIR/.github/workflows/deploy.yml" << 'WORKFLOW'
name: Deploy to Dokploy

on:
  push:
    branches: [main]

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Trigger Dokploy Deploy
        run: |
          curl -sf -X POST "${{ secrets.DOKPLOY_URL }}/api/application.deploy" \
            -H "x-api-key: ${{ secrets.DOKPLOY_API_KEY }}" \
            -H "Content-Type: application/json" \
            -d '{"applicationId": "${{ secrets.DOKPLOY_APP_ID }}"}'
          echo "✅ Deployment triggered"
WORKFLOW
  ok "Deploy workflow created"

  # 2. Set GitHub repo secrets
  info "Setting GitHub secrets..."

  _set_github_secret "DOKPLOY_URL" "$DOKPLOY_URL"
  _set_github_secret "DOKPLOY_API_KEY" "$DOKPLOY_API_KEY"
  _set_github_secret "DOKPLOY_APP_ID" "$DOKPLOY_APP_ID"
  ok "GitHub secrets configured (DOKPLOY_URL, DOKPLOY_API_KEY, DOKPLOY_APP_ID)"
}

_set_github_secret() {
  local SECRET_NAME="$1" SECRET_VALUE="$2"
  local KEY_RESPONSE KEY_ID PUBLIC_KEY ENCRYPTED

  KEY_RESPONSE=$(api_github GET "/repos/$GITHUB_USERNAME/$PROJECT_NAME/actions/secrets/public-key")
  KEY_ID=$(echo "$KEY_RESPONSE" | python3 -c "import json,sys;print(json.load(sys.stdin)['key_id'])")
  PUBLIC_KEY=$(echo "$KEY_RESPONSE" | python3 -c "import json,sys;print(json.load(sys.stdin)['key'])")

  ENCRYPTED=$(python3 -c "
from base64 import b64decode, b64encode
from nacl.public import PublicKey, SealedBox
pk = b64decode('$PUBLIC_KEY')
encrypted = SealedBox(PublicKey(pk)).encrypt(b'''$SECRET_VALUE''')
print(b64encode(encrypted).decode())
")

  api_github PUT "/repos/$GITHUB_USERNAME/$PROJECT_NAME/actions/secrets/$SECRET_NAME" \
    -d "{\"encrypted_value\":\"$ENCRYPTED\",\"key_id\":\"$KEY_ID\"}" > /dev/null 2>&1
}

# ═══════════════════════════════════════════════════════════════════
#  Push the deploy workflow
# ═══════════════════════════════════════════════════════════════════
push_workflow() {
  cd "$PROJECT_DIR"
  git add .github/
  git commit -q -m "ci: add auto-deploy workflow" 2>/dev/null || true
  local retries=0
  while ! git push origin main -q 2>/dev/null; do
    retries=$((retries + 1))
    [[ $retries -ge 5 ]] && { warn "Push failed after retries"; return 1; }
    sleep 2
  done
  ok "Deploy workflow pushed — every push to main triggers Dokploy deploy"
}

# ═══════════════════════════════════════════════════════════════════
#  Deploy: Trigger first build
# ═══════════════════════════════════════════════════════════════════
trigger_deploy() {
  info "Triggering deployment..."
  api_dokploy "application.deploy" \
    -d "{\"applicationId\":\"$DOKPLOY_APP_ID\"}" > /dev/null 2>&1 \
    && ok "Deployment triggered! Check $DOKPLOY_URL for build status." \
    || warn "Auto-deploy will happen on next push"
}

# ═══════════════════════════════════════════════════════════════════
#  COMMAND: deploy — Quick deploy from any project with .ship.json
# ═══════════════════════════════════════════════════════════════════
cmd_deploy() {
  load_config
  [[ -f ".ship.json" ]] || fail "No .ship.json found. Run 'ship new' first or cd into a ship'd project."

  local APP_ID=$(python3 -c "import json;print(json.load(open('.ship.json'))['dokploy_app_id'])")
  header "Deploying $(python3 -c "import json;print(json.load(open('.ship.json'))['name'])")"

  info "Pushing to GitHub..."
  git push origin main -q 2>/dev/null || git push -q 2>/dev/null

  info "Triggering Dokploy deploy..."
  api_dokploy "application.deploy" -d "{\"applicationId\":\"$APP_ID\"}" > /dev/null 2>&1

  ok "Deployed! 🚀"
}

# ═══════════════════════════════════════════════════════════════════
#  COMMAND: status — Check deployment status
# ═══════════════════════════════════════════════════════════════════
cmd_status() {
  load_config

  if [[ -f ".ship.json" ]]; then
    local APP_ID=$(python3 -c "import json;print(json.load(open('.ship.json'))['dokploy_app_id'])")
    local NAME=$(python3 -c "import json;print(json.load(open('.ship.json'))['name'])")
    local DOMAIN=$(python3 -c "import json;print(json.load(open('.ship.json'))['domain'])")

    header "Status: $NAME"
    echo -e "  Domain: https://$DOMAIN"

    local HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" "https://$DOMAIN" --max-time 5 2>/dev/null || echo "000")
    if [[ "$HTTP_STATUS" == "200" ]]; then
      echo -e "  App:    ${GREEN}● LIVE${NC} (HTTP $HTTP_STATUS)"
    else
      echo -e "  App:    ${YELLOW}○ HTTP $HTTP_STATUS${NC}"
    fi
  else
    header "All Dokploy Projects"
    curl -s "$DOKPLOY_URL/api/project.all" \
      -H "x-api-key: $DOKPLOY_API_KEY" | python3 -c "
import json,sys
for p in json.load(sys.stdin):
    apps = []
    for e in p.get('environments',[]):
        for a in e.get('applications',[]):
            apps.append(f\"{a['name']} ({a['applicationStatus']})\")
        for c in e.get('compose',[]):
            apps.append(f\"{c['name']} ({c['composeStatus']})\")
    print(f\"  {p['name']:20} {', '.join(apps) or 'empty'}\")
"
  fi
}

# ═══════════════════════════════════════════════════════════════════
#  COMMAND: destroy — Remove project from Dokploy + GitHub
# ═══════════════════════════════════════════════════════════════════
cmd_destroy() {
  load_config
  [[ -f ".ship.json" ]] || fail "No .ship.json found"

  local NAME=$(python3 -c "import json;print(json.load(open('.ship.json'))['name'])")
  local APP_ID=$(python3 -c "import json;print(json.load(open('.ship.json'))['dokploy_app_id'])")
  local PROJECT_ID=$(python3 -c "import json;print(json.load(open('.ship.json'))['dokploy_project_id'])")
  local DOMAIN=$(python3 -c "import json;print(json.load(open('.ship.json'))['domain'])")

  header "Destroy: $NAME"
  echo -e "${RED}This will delete the Dokploy app, DNS, tunnel route, and optionally the GitHub repo.${NC}"
  read -rp "Type project name to confirm: " CONFIRM
  [[ "$CONFIRM" == "$NAME" ]] || { echo "Aborted."; exit 0; }

  # 1. Delete Dokploy
  info "Deleting Dokploy application..."
  api_dokploy "application.delete" -d "{\"applicationId\":\"$APP_ID\"}" > /dev/null 2>&1 || true
  api_dokploy "project.remove" -d "{\"projectId\":\"$PROJECT_ID\"}" > /dev/null 2>&1 || true
  ok "Dokploy project removed"

  # 2. Remove Cloudflare DNS record
  if [[ -n "${CLOUDFLARE_API_TOKEN:-}" ]] && [[ -n "${CLOUDFLARE_ZONE_ID:-}" ]]; then
    info "Removing DNS record for $DOMAIN..."
    local DNS_ID
    DNS_ID=$(curl -sf "https://api.cloudflare.com/client/v4/zones/$CLOUDFLARE_ZONE_ID/dns_records?name=$DOMAIN" \
      -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN" | python3 -c "import json,sys;r=json.load(sys.stdin)['result'];print(r[0]['id'] if r else '')" 2>/dev/null)
    if [[ -n "$DNS_ID" ]]; then
      curl -sf -X DELETE "https://api.cloudflare.com/client/v4/zones/$CLOUDFLARE_ZONE_ID/dns_records/$DNS_ID" \
        -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN" > /dev/null 2>&1 && ok "DNS record removed" || warn "Could not remove DNS"
    fi
  fi

  # 3. Remove Cloudflare Tunnel ingress rule
  if [[ -n "${CF_TUNNEL_ID:-}" ]] && [[ -n "${CF_ACCOUNT_ID:-}" ]]; then
    info "Removing tunnel ingress rule..."
    local CURRENT_CONFIG NEW_CONFIG
    CURRENT_CONFIG=$(curl -sf "https://api.cloudflare.com/client/v4/accounts/$CF_ACCOUNT_ID/cfd_tunnel/$CF_TUNNEL_ID/configurations" \
      -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN")
    NEW_CONFIG=$(echo "$CURRENT_CONFIG" | python3 -c "
import json,sys
d=json.load(sys.stdin)
config=d['result']['config']
config['ingress']=[r for r in config['ingress'] if r.get('hostname')!='$DOMAIN']
print(json.dumps({'config':config}))
")
    curl -sf -X PUT "https://api.cloudflare.com/client/v4/accounts/$CF_ACCOUNT_ID/cfd_tunnel/$CF_TUNNEL_ID/configurations" \
      -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN" \
      -H "Content-Type: application/json" \
      -d "$NEW_CONFIG" > /dev/null 2>&1 && ok "Tunnel rule removed" || warn "Could not remove tunnel rule"
  fi

  # 4. GitHub repo
  read -rp "Also delete GitHub repo? [y/N] " DEL_REPO
  if echo "$DEL_REPO" | grep -qi 'y'; then
    api_github DELETE "/repos/$GITHUB_USERNAME/$NAME" > /dev/null 2>&1 \
      && ok "GitHub repo deleted" \
      || warn "Could not delete repo (may need delete_repo scope)"
  fi

  rm -f .ship.json
  ok "Project destroyed"
}

# ═══════════════════════════════════════════════════════════════════
#  Main
# ═══════════════════════════════════════════════════════════════════
case "${1:-}" in
  new)     cmd_new ;;
  deploy)  cmd_deploy ;;
  status)  cmd_status ;;
  destroy) cmd_destroy ;;
  *)
    echo -e "${BOLD}ship${NC} — Zero-fuss deploy to your TrueNAS infrastructure"
    echo ""
    echo -e "  ${CYAN}ship new${NC}       Create project → GitHub → Dokploy → Live"
    echo -e "  ${CYAN}ship deploy${NC}    Force-deploy current project"
    echo -e "  ${CYAN}ship status${NC}    Check deployment status"
    echo -e "  ${CYAN}ship destroy${NC}   Tear down project"
    echo ""
    echo -e "  ${DIM}Config: ~/.autodeploy/.env${NC}"
    ;;
esac
