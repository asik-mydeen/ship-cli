  ok "Express + TypeScript scaffold ready"
}

# ── Node.js: Fastify ──
scaffold_fastify() {
  local SUPA_ENV="$1"
  # Nearly identical to express, just swap framework
  scaffold_express "$SUPA_ENV"
  # Overwrite package.json deps
  sed -i '' 's/"express": "[^"]*"/"fastify": "^5.0.0"/' package.json 2>/dev/null || true
  sed -i '' '/"@types\/express"/d; /"cors"/d; /"@types\/cors"/d' package.json 2>/dev/null || true

  cat > src/index.ts << EOF
import Fastify from 'fastify'
import 'dotenv/config'

const app = Fastify({ logger: true })
const PORT = parseInt(process.env.PORT || '$APP_PORT')

app.get('/', async () => ({ status: 'ok', name: '$PROJECT_NAME' }))
app.get('/health', async () => ({ status: 'ok', uptime: process.uptime() }))

app.listen({ port: PORT, host: '0.0.0.0' })
EOF
  ok "Fastify + TypeScript scaffold ready"
}

# ── Python: FastAPI ──
scaffold_fastapi() {
  local SUPA_ENV="$1"

  cat > requirements.txt << EOF
fastapi>=0.115.0
uvicorn[standard]>=0.32.0
$(if ! echo "$USE_SUPABASE" | grep -qi 'n'; then echo "supabase>=2.10.0"; fi)
python-dotenv>=1.0.0
EOF

  cat > main.py << EOF
from fastapi import FastAPI
from dotenv import load_dotenv
import os

load_dotenv()

$(if ! echo "$USE_SUPABASE" | grep -qi 'n'; then echo "from supabase import create_client
supabase = create_client(os.getenv('SUPABASE_URL', ''), os.getenv('SUPABASE_SERVICE_ROLE_KEY', ''))"; fi)

app = FastAPI(title="$PROJECT_NAME", description="$PROJECT_DESC")

@app.get("/")
def root():
    return {"status": "ok", "name": "$PROJECT_NAME"}

@app.get("/health")
