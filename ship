    "start": "node dist/index.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0"$(if ! echo "$USE_SUPABASE" | grep -qi 'n'; then echo ',
    "@supabase/supabase-js": "^2.45.0"'; fi)
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
EOF

  cat > tsconfig.json << 'EOF'
{
  "compilerOptions": {
    "target": "ES2022", "module": "commonjs", "lib": ["ES2022"],
    "outDir": "dist", "rootDir": "src", "strict": true,
    "esModuleInterop": true, "resolveJsonModule": true,
    "skipLibCheck": true, "declaration": true
  },
