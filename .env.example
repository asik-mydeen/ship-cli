# Example .env — SECRETS (never commit this file)
# Copy to ~/.autodeploy/.env and fill in your values

# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
# Required scopes: repo, workflow, admin:repo_hook, delete_repo
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub username
GITHUB_USERNAME=your-username

# Cloudflare API Token
# Get from: https://dash.cloudflare.com/profile/api-tokens
# Create Custom Token with:
#   - Zone > DNS > Edit
#   - Account > Cloudflare Tunnel > Edit
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Cloudflare Zone ID
# Get from: Cloudflare dashboard > your domain > Overview > right sidebar
CLOUDFLARE_ZONE_ID=your-zone-id
